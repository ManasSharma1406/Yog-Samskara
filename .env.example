# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL for production, SQLite used when DATABASE_URL not set)
DATABASE_URL=postgres://user:password@localhost:5432/flownest_db

# JWT for Admin (Instructor) login
JWT_SECRET=your_super_secret_jwt_key_change_in_production
ADMIN_EMAIL=teacher@yogsamskara.com
ADMIN_PASSWORD=change_me_secure_password

# Firebase Admin SDK (REQUIRED for local dev - otherwise you get "metadata.google.internal ENOTFOUND")
# Get key: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Option 1: JSON string (escape quotes, or use single-line) - for Vercel/Heroku
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}
# Option 2: Path to the downloaded JSON file (recommended for local)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
